  <data name="1. Objeto" xml:space="preserve"><value>1. Objeto</value></data>
  <data name="O portal permite ao paciente visualizar e compartilhar resultados em caráter informativo e assistencial." xml:space="preserve"><value>O portal permite ao paciente visualizar e compartilhar resultados em caráter informativo e assistencial.</value></data>
