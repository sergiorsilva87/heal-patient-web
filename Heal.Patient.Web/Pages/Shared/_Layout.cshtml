<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @L["Portal do Paciente"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/portal.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    @{
        var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
        var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        var currentLanguageLabel = currentCulture switch
        {
            "en" => "EN",
            "es" => "ES",
            _ => "PT"
        };
        var currentLanguageFlag = currentCulture switch
        {
            "en" => "🇺🇸",
            "es" => "🇪🇸",
            _ => "🇧🇷"
        };
    }
    <a class="skip-link" href="#main-content">@L["Pular para o conteúdo principal"]</a>
    <header class="portal-navbar sticky-top">
        <nav class="navbar navbar-expand-md py-2" aria-label="@L["Navegação principal"]">
            <div class="container">

                <a class="navbar-brand d-flex align-items-center gap-2 py-0" asp-page="/Index">
                    <span class="portal-logo-mark">WM</span>
                    <span class="fw-semibold" style="color: var(--txt-primary)">@L["Clínica Imagem Saúde"]</span>
                </a>

                <button class="navbar-toggler border-0 shadow-none p-1" type="button"
                        data-bs-toggle="collapse" data-bs-target="#portalNav"
                        aria-controls="portalNav" aria-expanded="false"
                        aria-label="@L["Abrir menu"]">
                    <i class="bi bi-list" style="font-size:1.6rem; color: var(--txt-secondary)"></i>
                </button>

                <div class="collapse navbar-collapse" id="portalNav">
                    <ul class="navbar-nav ms-auto align-items-md-center gap-md-1 pt-3 pb-2 pt-md-0 pb-md-0 portal-header-actions">

                        <li class="nav-item">
                            <div class="btn-group btn-group-sm" role="group" aria-label="@L["Ajuste de fonte"]">
                                <button id="font-decrease" class="btn btn-outline-secondary" type="button" aria-label="@L["Diminuir fonte"]">A<sup>−</sup></button>
                                <button id="font-increase" class="btn btn-outline-secondary" type="button" aria-label="@L["Aumentar fonte"]">A<sup>+</sup></button>
                            </div>
                        </li>

                        <li class="nav-item">
                            <a class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1" asp-page="/Help">
                                <i class="bi bi-question-circle"></i>
                                <span>@L["Ajuda"]</span>
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <button class="btn btn-sm btn-outline-dark dropdown-toggle d-flex align-items-center gap-1"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                <span>@currentLanguageFlag</span>
                                <span>@currentLanguageLabel</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-page="/Culture" asp-route-culture="pt-BR" asp-route-returnUrl="@returnUrl">🇧🇷 Português (BR)</a></li>
                                <li><a class="dropdown-item" asp-page="/Culture" asp-route-culture="es" asp-route-returnUrl="@returnUrl">🇪🇸 Español</a></li>
                                <li><a class="dropdown-item" asp-page="/Culture" asp-route-culture="en" asp-route-returnUrl="@returnUrl">🇺🇸 English</a></li>
                            </ul>
                        </li>

                        @if ((bool?)ViewData["ShowExit"] == true)
                        {
                            <li class="nav-item">
                                <a class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1" asp-page="/Index">
                                    <i class="bi bi-box-arrow-right"></i>
                                    <span>@L["Sair"]</span>
                                </a>
                            </li>
                        }

                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <main id="main-content" class="container py-4 flex-grow-1" tabindex="-1">
        @RenderBody()
    </main>

    <footer class="mt-auto" style="border-top: 1px solid var(--border); background: var(--bg-card)">
        <div class="container py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <small class="text-muted">&copy; 2026 @L["Clínica Imagem Saúde"]</small>
            <nav aria-label="@L["Links do rodapé"]" class="d-flex gap-3">
                <a asp-page="/Terms" class="text-muted small text-decoration-none">@L["Termos"]</a>
                <a asp-page="/Privacy" class="text-muted small text-decoration-none">@L["Privacidade"]</a>
            </nav>
        </div>
    </footer>

    <partial name="_CookieConsentPartial" />

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
