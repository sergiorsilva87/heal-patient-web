<div id="cookieBanner" class="cookie-banner d-none">
    <div class="container py-3">
        <div class="row align-items-center g-2">
            <div class="col">
                <p class="mb-0 small">
                    @L["Utilizamos cookies essenciais para funcionamento do portal. Ao continuar, você concorda com nossa política e termos."]
                    <a class="link-light fw-medium" asp-page="/Terms">@L["Termos"]</a>
                    &middot;
                    <a class="link-light fw-medium" asp-page="/Privacy">@L["Privacidade"]</a>
                </p>
            </div>
            <div class="col-auto">
                <button id="cookieAccept" class="btn btn-sm btn-light fw-semibold px-4">@L["Aceitar"]</button>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
  const key = 'portal_cookie_accept';
  const banner = document.getElementById('cookieBanner');
  const btn = document.getElementById('cookieAccept');

  if (!banner || !btn) return;

  if (!localStorage.getItem(key)) {
    banner.classList.remove('d-none');
  }

  btn.addEventListener('click', function () {
    localStorage.setItem(key, '1');
    banner.classList.add('d-none');
  });
})();
</script>
