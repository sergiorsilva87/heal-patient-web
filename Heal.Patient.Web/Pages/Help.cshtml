@page
@model Heal.Patient.Web.Pages.HelpModel
@{
    ViewData["Title"] = L["Central de Ajuda"];
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-9 col-xl-8">
        <div class="portal-card p-4 p-lg-5">
            <h1 class="h3 fw-bold mb-4">@L["Central de Ajuda"]</h1>

            <section class="mb-5">
                <h2 id="h-faq" class="portal-anchor-heading h5 fw-bold mb-4">
                    @L["Perguntas frequentes"]
                    <a class="anchor-link" href="#h-faq" aria-hidden="true">#</a>
                </h2>
                <div class="accordion portal-accordion" id="faqAccordion">
                    @for (var i = 0; i < Model.FaqItems.Length; i++)
                    {
                        var item = Model.FaqItems[i];
                        <div class="accordion-item">
                            <h3 class="accordion-header" id="heading-@i">
                                <button class="accordion-button @(i == 0 ? string.Empty : "collapsed")"
                                        type="button" data-bs-toggle="collapse"
                                        data-bs-target="#collapse-@i"
                                        aria-expanded="@(i == 0 ? "true" : "false")"
                                        aria-controls="collapse-@i">
                                    @item.Question
                                </button>
                            </h3>
                            <div id="collapse-@i"
                                 class="accordion-collapse collapse @(i == 0 ? "show" : string.Empty)"
                                 data-bs-parent="#faqAccordion">
                                <div class="accordion-body">@item.Answer</div>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <section class="mb-5">
                <h2 id="h-contact" class="portal-anchor-heading h5 fw-bold mb-3">
                    @L["Contato da clínica"]
                    <a class="anchor-link" href="#h-contact" aria-hidden="true">#</a>
                </h2>
                <div class="portal-subcard p-3 d-flex flex-column gap-1">
                    <p class="mb-0">
                        <i class="bi bi-telephone me-2" style="color: var(--clr-primary-700)"></i>
                        <strong>@L["Telefone"]</strong>: (11) 3000-0000
                    </p>
                    <p class="mb-0">
                        <i class="bi bi-envelope me-2" style="color: var(--clr-primary-700)"></i>
                        <strong>@L["E-mail"]</strong>:
                        <a href="mailto:atendimento@clinica-abc.com.br" class="portal-back-link">atendimento@clinica-abc.com.br</a>
                    </p>
                </div>
            </section>

            <section class="mb-5">
                <h2 id="h-access" class="portal-anchor-heading h5 fw-bold mb-3">
                    @L["Como acessar meu exame"]
                    <a class="anchor-link" href="#h-access" aria-hidden="true">#</a>
                </h2>
                <ol class="portal-prose">
                    <li>@L["Informe número de protocolo e data de nascimento."]</li>
                    <li>@L["Ou use CPF e código de acesso temporário."]</li>
                    <li>@L["Abra laudo, imagens, PDF e compartilhamento via QR Code."]</li>
                </ol>
            </section>

            <div class="pt-3" style="border-top: 1px solid var(--border)">
                <a class="portal-back-link" asp-page="/Index">
                    <i class="bi bi-arrow-left me-1"></i>@L["Voltar para login"]
                </a>
            </div>
        </div>
    </div>
</div>
