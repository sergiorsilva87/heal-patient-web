@page
@model Heal.Patient.Web.Pages.Exam.ImagesModel
@{
    ViewData["Title"] = L["Imagens do exame"];
    ViewData["ShowExit"] = true;
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <div>
        <h1 class="h4 mb-1">@L["Imagens do exame"]</h1>
        <p class="text-muted mb-0 small">dwv v0.36.3</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        @if (Model.AllowImageZipDownload)
        {
            <a class="btn btn-outline-secondary"
               asp-page="/Exam/Images"
               asp-page-handler="DownloadImagesZip">
                <i class="bi bi-file-zip me-1"></i>@L["Baixar imagens (ZIP)"]
            </a>
        }
        <button id="print" class="btn btn-primary" type="button">
            <i class="bi bi-printer me-1"></i>@L["Imprimir imagens"]
        </button>
    </div>
</div>

<section class="portal-print-shell" role="region" aria-label="@L["Imagens do exame"]">
    <div class="portal-dwv-shell">
        <div class="portal-dwv-canvas-wrap">
            <div class="portal-dwv-overlay portal-dwv-overlay-left-top">
                <div>20120215_ASLtest_human [M]</div>
                <div>01/01/1983</div>
            </div>
            <div class="portal-dwv-overlay portal-dwv-overlay-right-top text-end">
                <div>SIEMENS TrioTim</div>
                <div>15/02/2012 15:50:13</div>
                <div>MR</div>
            </div>
            <div class="portal-dwv-overlay portal-dwv-overlay-left-bottom">
                <div>WC: 424</div>
                <div>WW: 884</div>
            </div>

            <div class="portal-dwv-image-slice" aria-hidden="true"></div>
        </div>

        <div class="portal-dwv-controls">
            <fieldset class="portal-dwv-box">
                <legend>Position / Layout / Resample</legend>
                <div class="portal-dwv-line">
                    <label class="me-2">Position:</label>
                    <input type="text" class="form-control form-control-sm portal-dwv-input" readonly value="" />
                </div>
                <div class="portal-dwv-line portal-dwv-wrap">
                    <label class="me-2">Layout:</label>
                    <select class="form-select form-select-sm portal-dwv-select" disabled>
                        <option>1*1</option>
                    </select>
                    <button class="btn btn-sm btn-outline-secondary" type="button" disabled>Reset views</button>
                    <label class="d-flex align-items-center gap-1 mb-0"><input type="checkbox" disabled /> Smoothing</label>
                </div>
                <div class="portal-dwv-line portal-dwv-wrap mb-0">
                    <span class="me-2">Resample:</span>
                    <button class="btn btn-sm btn-outline-secondary" type="button" disabled>X+</button>
                    <button class="btn btn-sm btn-outline-secondary" type="button" disabled>Y+</button>
                    <button class="btn btn-sm btn-outline-secondary" type="button" disabled>Z+</button>
                    <button class="btn btn-sm btn-outline-secondary" type="button" disabled>Match</button>
                    <button class="btn btn-sm btn-outline-secondary" type="button" disabled>Reset</button>
                </div>
            </fieldset>

            <fieldset class="portal-dwv-box">
                <legend>Binders</legend>
                <label><input type="checkbox" checked disabled /> WindowLevel</label>
                <label><input type="checkbox" checked disabled /> Position</label>
                <label><input type="checkbox" checked disabled /> Zoom</label>
                <label><input type="checkbox" checked disabled /> Offset</label>
                <label><input type="checkbox" checked disabled /> Opacity</label>
                <label><input type="checkbox" checked disabled /> ColourMap</label>
                <label><input type="checkbox" checked disabled /> MaskView</label>
                <label><input type="checkbox" checked disabled /> all</label>
            </fieldset>

            <fieldset class="portal-dwv-box">
                <legend>Tools</legend>
                <label><input type="radio" name="dwv-tool" checked disabled /> Scroll</label>
                <label><input type="radio" name="dwv-tool" disabled /> WindowLevel</label>
                <label><input type="radio" name="dwv-tool" disabled /> ZoomAndPan</label>
                <label><input type="radio" name="dwv-tool" disabled /> Opacity</label>
                <label><input type="radio" name="dwv-tool" disabled /> Draw</label>
                <label><input type="radio" name="dwv-tool" disabled /> Brush</label>
                <label><input type="radio" name="dwv-tool" disabled /> Floodfill</label>
                <label><input type="radio" name="dwv-tool" disabled /> Livewire</label>
                <label><input type="radio" name="dwv-tool" disabled /> Filter</label>
            </fieldset>

            <fieldset class="portal-dwv-box">
                <legend>Sliders</legend>
                <div class="portal-dwv-grid">
                    <div class="portal-dwv-cell"><strong>Id</strong><div>0</div></div>
                    <div class="portal-dwv-cell"><strong>LG0</strong><div>- A C S</div></div>
                    <div class="portal-dwv-cell"><strong>Contrast</strong><div>width 884,0 | center 424,0</div></div>
                    <div class="portal-dwv-cell"><strong>Preset</strong><div>wl: Algo1 | cm: plain</div></div>
                    <div class="portal-dwv-cell"><strong>Alpha</strong><div>opacity 1,000</div></div>
                    <div class="portal-dwv-cell"><strong>Alpha Range</strong><div>min 0,000 | max 1130</div></div>
                </div>
            </fieldset>
        </div>
    </div>
</section>

<p class="mt-3 mb-0">
    <a class="portal-back-link" asp-page="/Exam/Index"><i class="bi bi-arrow-left me-1"></i>@L["Voltar"]</a>
</p>

@section Scripts {
    <script>
        (function () {
            const printButton = document.getElementById('print');
            if (!printButton) return;

            printButton.addEventListener('click', async function () {
                try {
                    await fetch('@Url.Page("/Exam/Images", "RegisterPrint")', {
                        method: 'GET',
                        credentials: 'same-origin'
                    });
                } catch {
                    // Keep print flow working even if telemetry request fails.
                } finally {
                    window.print();
                }
            });
        })();
    </script>
}
