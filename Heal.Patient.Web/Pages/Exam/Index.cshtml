@page "/exam"
@model Heal.Patient.Web.Pages.Exam.IndexModel
@{
    ViewData["Title"] = L["Meu exame"];
    ViewData["ShowExit"] = true;
}

<section class="portal-panel p-4 mb-4">
    <div class="d-flex align-items-center gap-2 flex-wrap">
        <h1 class="h4 mb-0">@L["Olá {0} meus parabéns!", Model.PatientName]</h1>
        <span class="portal-chip"><i class="bi bi-check-circle-fill me-1"></i>@L["Resultado disponível"]</span>
    </div>
    <p class="text-muted mb-0 mt-2" style="font-size: var(--fs-sm)">@L["Confira o status abaixo para saber o próximo passo em cada exame."]</p>
</section>

<article class="portal-card p-4 mb-4">
    <h2 class="portal-exam-eyebrow mb-3">@L["Dados do paciente"]</h2>
    <dl class="portal-exam-dl">
        <div><dt>@L["Nome"]</dt><dd>@Model.PatientName</dd></div>
        <div><dt>@L["ID do paciente"]</dt><dd>@Model.PatientId</dd></div>
        <div><dt>@L["Data de nascimento"]</dt><dd>@Model.PatientBirthDate</dd></div>
        <div><dt>@L["CPF"]</dt><dd>@Model.PatientCpfMasked</dd></div>
    </dl>
</article>

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h2 class="h5 mb-0">@L["Exames"]</h2>
    <form method="get" class="d-flex align-items-center flex-wrap gap-3 portal-page-size-form">
        <div class="form-check mb-0 d-flex align-items-center gap-1">
            <input class="form-check-input" type="checkbox" id="showArchived" name="showArchived" value="true"
                   @(Model.ShowArchived ? "checked" : string.Empty) onchange="this.form.submit()" />
            <label class="form-check-label small text-muted text-nowrap" for="showArchived">
                @L["Listar exames antigos e arquivados"]
            </label>
            <button type="button" class="btn btn-link p-0 lh-1 text-muted" style="font-size: var(--fs-sm)"
                    data-bs-toggle="popover" data-bs-placement="top" data-bs-trigger="click focus"
                    data-bs-title="@L["O que são exames arquivados?"]"
                    data-bs-content="@L["Exames mais antigos são guardados em um servidor seguro especializado em armazenamento de longa duração na nuvem — assim seus dados ficam protegidos por muito mais tempo! Caso queira baixar um desses exames, precisamos recuperá-lo primeiro. Esse processo é tranquilo, mas pode levar até algumas horas. Não se preocupe: você será avisado assim que o arquivo estiver pronto para download."]"
                    aria-label="@L["Saiba mais sobre exames arquivados"]">
                <i class="bi bi-question-circle"></i>
            </button>
        </div>
        <div class="d-flex align-items-center gap-2">
            <label class="small mb-0 text-nowrap text-muted" for="pageSize">@L["Itens por página"]</label>
            <select id="pageSize" name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="5" selected="@(Model.PageSize == 5 ? "selected" : null)">5</option>
                <option value="10" selected="@(Model.PageSize == 10 ? "selected" : null)">10</option>
                <option value="20" selected="@(Model.PageSize == 20 ? "selected" : null)">20</option>
                <option value="50" selected="@(Model.PageSize == 50 ? "selected" : null)">50</option>
            </select>
        </div>
        <input type="hidden" name="page" value="1" />
    </form>
</div>

<p class="small text-muted mb-3">@L["Mostrando {0} a {1} de {2} exames.", Model.StartItemNumber, Model.EndItemNumber, Model.TotalItems]</p>

<div class="d-flex flex-column gap-3">
    @if (Model.PagedExams.Count == 0)
    {
        <article class="portal-card p-4 text-center">
            <i class="bi bi-folder2-open" style="font-size: 2rem; color: var(--txt-muted)"></i>
            <p class="mb-0 mt-2 text-muted">@L["Nenhum exame encontrado."]</p>
        </article>
    }

    @for (var i = 0; i < Model.PagedExams.Count; i++)
    {
        var exam = Model.PagedExams[i];
        var statusText = exam.StatusCode switch
        {
            "ready-report" => L["Pronto para laudo"],
            "images-available" => L["Imagens disponíveis"],
            "cold-storage" => L["Arquivado"],
            _ => L["Em processamento"]
        };
        var statusDetail = exam.StatusCode switch
        {
            "ready-report" => L["Laudo pronto para visualização e download em PDF."],
            "images-available" => L["Imagens prontas para visualização e impressão."],
            "cold-storage" => L["Este exame está em nosso servidor de backup na nuvem. Ao solicitar o download, o arquivo ficará disponível em até algumas horas."],
            _ => L["Estamos finalizando o processamento. Tente novamente em alguns minutos."]
        };
        var statusClass = exam.StatusCode switch
        {
            "ready-report" => "portal-status portal-status-ready",
            "images-available" => "portal-status portal-status-images",
            "cold-storage" => "portal-status portal-status-archived",
            _ => "portal-status portal-status-processing"
        };
        var statusIcon = exam.StatusCode switch
        {
            "ready-report" => "bi-file-earmark-medical",
            "images-available" => "bi-images",
            "cold-storage" => "bi-archive",
            _ => "bi-hourglass-split"
        };

        <article class="portal-exam-card">
            <div class="portal-exam-band">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                    <div>
                        <div class="portal-exam-eyebrow">@L["Dados do exame"] #@(Model.StartItemNumber + i)</div>
                        <h3 class="portal-exam-title">@exam.Type</h3>
                    </div>
                    <span class="@statusClass"><i class="bi @statusIcon me-1"></i>@statusText</span>
                </div>

                <dl class="portal-exam-dl">
                    <div><dt>@L["Número de protocolo"]</dt><dd>@exam.Protocol</dd></div>
                    <div><dt>@L["Número de acesso"]</dt><dd>@exam.AccessNumber</dd></div>
                    <div><dt>@L["Procedimento"]</dt><dd>@exam.Procedure</dd></div>
                    <div><dt>@L["Unidade"]</dt><dd>@exam.UnitName</dd></div>
                </dl>
            </div>

            <div class="portal-exam-band">
                <dl class="portal-exam-dl">
                    <div><dt>@L["Data do exame"]</dt><dd>@exam.Date</dd></div>
                    <div><dt>@L["Data do laudo"]</dt><dd>@exam.ReportDateText</dd></div>
                    <div><dt>@L["Médico executor"]</dt><dd>@exam.PerformingDoctor <span class="text-muted">(@exam.PerformingDoctorCrm / @exam.PerformingDoctorCrmUf)</span></dd></div>
                    <div><dt>@L["Médico solicitante"]</dt><dd>@exam.RequestingDoctor @if (!string.IsNullOrWhiteSpace(exam.RequestingDoctorCrm)) { <span class="text-muted">(@exam.RequestingDoctorCrm / @exam.RequestingDoctorCrmUf)</span> } else { <span class="text-muted">(@L["Não informado no DICOM"])</span> }</dd></div>
                    <div><dt>@L["Técnico de radiologia"]</dt><dd>@exam.RadiologyTechnicianName</dd></div>
                    <div><dt>@L["Registro do técnico (CRTR)"]</dt><dd>@exam.RadiologyTechnicianRegistry / @exam.RadiologyTechnicianRegistryUf</dd></div>
                </dl>
                <p class="small text-muted mt-3 mb-0"><i class="bi bi-info-circle me-1"></i>@statusDetail</p>
            </div>

            <div class="portal-exam-band portal-exam-band-actions">
                <div class="portal-exam-eyebrow mb-2">@L["Ações do exame"]</div>
                <div class="row g-2">
                    <div class="col-12 col-md-4">
                        <a class="portal-action-tile" asp-page="/Exam/Report">
                            <span class="portal-action-tile-icon"><i class="bi bi-file-earmark-text"></i></span>
                            <span class="portal-action-tile-text">
                                <span class="portal-action-tile-label">@L["Laudo"]</span>
                                <span class="portal-action-tile-hint">@L["Abrir laudo e baixar PDF"]</span>
                            </span>
                        </a>
                    </div>
                    <div class="col-12 col-md-4">
                        <a class="portal-action-tile" asp-page="/Exam/Images">
                            <span class="portal-action-tile-icon"><i class="bi bi-images"></i></span>
                            <span class="portal-action-tile-text">
                                <span class="portal-action-tile-label">@L["Imagens"]</span>
                                <span class="portal-action-tile-hint">@L["Abrir visualizador de imagens"]</span>
                            </span>
                        </a>
                    </div>
                    <div class="col-12 col-md-4">
                        <a class="portal-action-tile" asp-page="/Exam/QrCode">
                            <span class="portal-action-tile-icon"><i class="bi bi-qr-code"></i></span>
                            <span class="portal-action-tile-text">
                                <span class="portal-action-tile-label">@L["Compartilhar"]</span>
                                <span class="portal-action-tile-hint">@L["Abrir QR Code de compartilhamento"]</span>
                            </span>
                        </a>
                    </div>
                </div>
            </div>
        </article>
    }
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-4 portal-pagination-wrap" aria-label="@L["Paginação de exames"]">
        <span class="small text-muted mb-0">@L["Página {0} de {1}.", Model.CurrentPage, Model.TotalPages]</span>
        <ul class="pagination mb-0">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : string.Empty)">
                @if (Model.CurrentPage == 1)
                {
                    <span class="page-link"><i class="bi bi-chevron-left"></i><span class="visually-hidden">@L["Anterior"]</span></span>
                }
                else
                {
                    <a class="page-link" asp-page="/Exam/Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-pageSize="@Model.PageSize" asp-route-showArchived="@Model.ShowArchived" aria-label="@L["Anterior"]"><i class="bi bi-chevron-left"></i></a>
                }
            </li>

            @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
            {
                <li class="page-item @(pageNumber == Model.CurrentPage ? "active" : string.Empty)">
                    <a class="page-link" asp-page="/Exam/Index" asp-route-page="@pageNumber" asp-route-pageSize="@Model.PageSize" asp-route-showArchived="@Model.ShowArchived">@pageNumber</a>
                </li>
            }

            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : string.Empty)">
                @if (Model.CurrentPage == Model.TotalPages)
                {
                    <span class="page-link"><i class="bi bi-chevron-right"></i><span class="visually-hidden">@L["Próxima"]</span></span>
                }
                else
                {
                    <a class="page-link" asp-page="/Exam/Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-pageSize="@Model.PageSize" asp-route-showArchived="@Model.ShowArchived" aria-label="@L["Próxima"]"><i class="bi bi-chevron-right"></i></a>
                }
            </li>
        </ul>
    </nav>
}

<p class="text-center mt-4 small">
    <i class="bi bi-question-circle" style="color: var(--txt-muted)"></i>
    <a asp-page="/Help" class="portal-back-link ms-1">@L["Se não encontrar seu exame, toque em Ajuda."]</a>
</p>

@section Scripts {
    <script>
        document.querySelectorAll('[data-bs-toggle="popover"]').forEach(function (el) {
            new bootstrap.Popover(el);
        });
    </script>
}
