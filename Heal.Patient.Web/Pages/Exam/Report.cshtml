@page
@model Heal.Patient.Web.Pages.Exam.ReportModel
@{
    ViewData["Title"] = L["Laudo médico"];
    ViewData["ShowExit"] = true;

    string FileKind(string fileName)
    {
        var extension = System.IO.Path.GetExtension(fileName)?.ToLowerInvariant();
        return extension switch
        {
            ".pdf" => "pdf",
            ".doc" or ".docx" => "word",
            ".xls" or ".xlsx" => "excel",
            ".png" or ".jpg" or ".jpeg" => "image",
            _ => "generic"
        };
    }

    string RoleLabel(string role) => role switch
    {
        "reception" => L["Recepção"],
        "radiology-technician" => L["Técnico de radiologia"],
        "room-assistant" => L["Auxiliar de sala"],
        _ => role
    };
}

<div class="portal-actions-bar mb-3">
    <a class="btn btn-outline-secondary" asp-page="/Exam/Index">
        <i class="bi bi-arrow-left me-1"></i>@L["Voltar"]
    </a>
    <a class="btn btn-primary ms-auto" asp-page="/Exam/ColdStorage">
        <i class="bi bi-download me-1"></i>@L["Baixar PDF"]
    </a>
</div>

<article class="portal-card p-4 p-md-5">
    <header class="portal-report-header portal-report-header-compact mb-3">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
            <div class="d-flex align-items-center gap-2">
                <span class="portal-logo-mark">WM</span>
                <div>
                    <h2 class="h6 mb-0">@Model.FacilityName</h2>
                    <p class="small mb-0 text-muted">@L["CNPJ"]: @Model.FacilityCnpj</p>
                </div>
            </div>
            <span class="small text-muted">@L["Cabeçalho institucional"]</span>
        </div>

        <h1 class="h5 mb-2">@L["Laudo médico"]</h1>

        <div class="portal-report-meta-lines small">
            <p class="mb-1"><strong>@L["Nome"]:</strong> @Model.PatientName | <strong>@L["ID do paciente"]:</strong> @Model.PatientId | <strong>@L["Data de nascimento"]:</strong> @Model.PatientBirthDate</p>
            <p class="mb-0"><strong>@L["Número de protocolo"]:</strong> @Model.Protocol | <strong>@L["Número de acesso"]:</strong> @Model.AccessNumber | <strong>@L["Tipo"]:</strong> @Model.ExamType | <strong>@L["Data do exame"]:</strong> @Model.ExamDate | <strong>@L["Data do laudo"]:</strong> @Model.ReportDate</p>
        </div>
    </header>

    <section class="mb-3">
        <h2 class="h6 mb-2">@L["Dados clínicos do exame"]</h2>
        <div class="portal-clinical-grid small">
            <p><strong>@L["Procedimento"]:</strong> @Model.Procedure</p>
            <p><strong>@L["Unidade"]:</strong> @Model.UnitName</p>
            <p><strong>@L["Médico executor"]:</strong> @Model.PerformingDoctor</p>
            <p><strong>@L["CRM do médico executor"]:</strong> @Model.PerformingDoctorCrm / @Model.PerformingDoctorCrmUf</p>
            <p><strong>@L["Médico solicitante"]:</strong> @Model.RequestingDoctor</p>
            <p><strong>@L["CRM do médico solicitante"]:</strong> @(string.IsNullOrWhiteSpace(Model.RequestingDoctorCrm) ? L["Não informado no DICOM"] : $"{Model.RequestingDoctorCrm} / {Model.RequestingDoctorCrmUf}")</p>
            <p><strong>@L["Técnico de radiologia"]:</strong> @Model.RadiologyTechnicianName</p>
            <p><strong>@L["Registro do técnico (CRTR)"]:</strong> @Model.RadiologyTechnicianRegistry / @Model.RadiologyTechnicianRegistryUf</p>
        </div>
    </section>

    <section class="mb-4">@Html.Raw(Model.ReportBody)</section>

    <section class="portal-signature-block mb-4" aria-label="@L["Assinatura do médico"]">
        <p class="small mb-1 fw-semibold">@L["Assinatura do médico"]</p>
        <img class="portal-signature-image" src="~/img/signature-doctor.svg" alt="@L["Assinatura do médico"]" />
        <p class="small text-muted mb-0">
            @L["Assinado por"]: @Model.PerformingDoctor | @L["CRM do médico executor"]: @Model.PerformingDoctorCrm / @Model.PerformingDoctorCrmUf
        </p>
    </section>

    <hr class="portal-report-separator my-4" />

    <section class="mb-3">
        <h2 class="h6">@L["Adendo"]</h2>

        @foreach (var addendum in Model.Addendums)
        {
            <article class="p-0 mb-2">
                <p class="small text-muted mb-2">
                    <strong>@L["Data do adendo"]:</strong> @addendum.DateText |
                    <strong>@L["Médico do adendo"]:</strong> @addendum.PhysicianName |
                    <strong>@L["CRM do médico do adendo"]:</strong> @addendum.PhysicianCrm / @addendum.PhysicianCrmUf
                </p>
                <p class="mb-0">@addendum.Body</p>
                <div class="portal-signature-block mt-3" aria-label="@L["Assinatura do médico"]">
                    <p class="small mb-1 fw-semibold">@L["Assinatura do médico"]</p>
                    <img class="portal-signature-image" src="~/img/signature-doctor.svg" alt="@L["Assinatura do médico"]" />
                    <p class="small text-muted mb-0">
                        @L["Assinado por"]: @addendum.PhysicianName | @L["CRM do médico do adendo"]: @addendum.PhysicianCrm / @addendum.PhysicianCrmUf
                    </p>
                </div>
            </article>
        }
    </section>

    <footer class="portal-report-footer p-3 mt-3">
        <p class="mb-1"><strong>@L["Rodapé institucional"]:</strong> @Model.FacilityFooterText</p>
        <p class="mb-1">@Model.FacilityAddress</p>
        <p class="mb-0">@L["Telefone"]: @Model.FacilityPhone | @L["E-mail"]: @Model.FacilityEmail</p>
    </footer>
</article>

<section class="portal-card p-4 mt-4">
    <h2 class="h6 mb-3"><i class="bi bi-paperclip me-1"></i>@L["Arquivos anexados ao exame"]</h2>

    @if (Model.Attachments.Count == 0)
    {
        <p class="text-muted mb-0">@L["Nenhum arquivo anexado ao exame."]</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@L["Data do anexo"]</th>
                        <th>@L["Arquivo"]</th>
                        <th>@L["Anexado por"]</th>
                        <th>@L["Perfil"]</th>
                        <th class="text-end">@L["Download"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var attachment in Model.Attachments)
                    {
                        var kind = FileKind(attachment.FileName);
                        <tr>
                            <td>@attachment.AttachedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                    <div class="portal-file-cell">
                                        <span class="portal-file-icon portal-file-icon-@kind" aria-hidden="true">@kind.ToUpperInvariant()</span>
                                        <span class="portal-file-name" title="@attachment.FileName">@attachment.FileName</span>
                                    </div>
                            </td>
                            <td>@attachment.UploadedByName</td>
                            <td>@RoleLabel(attachment.UploadedByRole)</td>
                            <td class="text-end">
                                          <a class="btn btn-sm btn-outline-primary portal-table-action"
                                   asp-page="/Exam/Report"
                                   asp-page-handler="DownloadAttachment"
                                   asp-route-attachmentId="@attachment.Id">
                                    <i class="bi bi-download me-1"></i>@L["Baixar arquivo"]
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

<section class="portal-card p-4 mt-4">
    <h2 class="h6 mb-3"><i class="bi bi-chat-square-text me-1"></i>@L["Solicitações e documentos complementares"]</h2>

    @if (TempData["SupportingDocumentSuccess"] is string uploadedFileName)
    {
        <div class="alert alert-success py-2" role="status">@L["Documento enviado com sucesso: {0}", uploadedFileName]</div>
    }
    @if (TempData["SupportingDocumentError"]?.ToString() == "required")
    {
        <div class="alert alert-warning py-2" role="alert">@L["Selecione um documento para enviar."]</div>
    }
    @if (TempData["SupportingDocumentError"]?.ToString() == "not-allowed")
    {
        <div class="alert alert-warning py-2" role="alert">@L["Este tenant não permite envio de documentos pelo paciente."]</div>
    }

    @if (TempData["ReviewRequestSuccess"] is not null)
    {
        <div class="alert alert-success py-2" role="status">@L["Solicitação de revisão enviada com sucesso."]</div>
    }
    @if (TempData["ReviewRequestError"]?.ToString() == "required")
    {
        <div class="alert alert-warning py-2" role="alert">@L["Preencha o solicitante e o motivo da revisão."]</div>
    }
    @if (TempData["ReviewRequestError"]?.ToString() == "not-allowed")
    {
        <div class="alert alert-warning py-2" role="alert">@L["Este tenant não permite solicitação de revisão para o perfil informado."]</div>
    }

    <div class="row g-3">
        <div class="col-12 col-lg-6">
            <div class="portal-subcard p-3">
                <h3 class="h6 mb-2">@L["Enviar documento complementar"]</h3>
                @if (Model.AllowPatientSupportingDocumentsUpload)
                {
                    <p class="small text-muted mb-2">@L["Envie documentos em anexo que ainda não foram liberados para laudo."]</p>
                    <form method="post" enctype="multipart/form-data" asp-page-handler="UploadSupportingDocument" class="d-flex flex-column gap-2">
                        <input class="form-control" type="file" name="SupportingDocumentFile" />
                        <button class="btn btn-outline-primary align-self-start" type="submit">@L["Enviar documento"]</button>
                    </form>
                }
                else
                {
                    <p class="small text-muted mb-0">@L["Envio de documentos pelo paciente está desabilitado para este tenant."]</p>
                }
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="portal-subcard p-3">
                <h3 class="h6 mb-2">@L["Solicitar revisão de laudo"]</h3>
                <p class="small text-muted mb-2">@L["As regras de revisão podem variar conforme configuração do tenant."]</p>
                @if (Model.AllowExternalPhysicianReviewRequest || Model.AllowPatientOrGuardianReviewRequest || Model.AllowInternalPhysicianReviewRequest)
                {
                    <form method="post" asp-page-handler="SubmitReviewRequest" class="d-flex flex-column gap-2">
                        <label class="form-label mb-0" for="reviewRequesterType">@L["Solicitante"]</label>
                        <select id="reviewRequesterType" name="ReviewRequesterType" class="form-select">
                            <option value="">@L["Selecione"]</option>
                            @if (Model.AllowExternalPhysicianReviewRequest)
                            {
                                <option value="external-physician">@L["Médico solicitante externo (fora do corpo clínico)"]</option>
                            }
                            @if (Model.AllowPatientOrGuardianReviewRequest)
                            {
                                <option value="patient-or-guardian">@L["Paciente ou responsável legal"]</option>
                            }
                            @if (Model.AllowInternalPhysicianReviewRequest)
                            {
                                <option value="internal-physician">@L["Médico solicitante interno (corpo clínico)"]</option>
                            }
                        </select>

                        <label class="form-label mb-0" for="reviewReason">@L["Motivo da revisão"]</label>
                        <textarea id="reviewReason" name="ReviewRequestReason" rows="3" class="form-control"></textarea>

                        <button class="btn btn-outline-primary align-self-start" type="submit">@L["Enviar solicitação de revisão"]</button>
                    </form>
                }
                else
                {
                    <p class="small text-muted mb-0">@L["Solicitação de revisão está desabilitada para este tenant."]</p>
                }
            </div>
        </div>
    </div>
</section>
