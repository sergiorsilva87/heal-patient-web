{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Heal.Patient.Web",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet: build",
      "program": "${workspaceFolder}/Heal.Patient.Web/bin/Debug/net10.0/Heal.Patient.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/Heal.Patient.Web",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ]
}
